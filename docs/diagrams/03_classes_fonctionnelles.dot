
digraph G {
  graph [pad="0.3", nodesep="0.4", ranksep="0.8", fontname="Arial", bgcolor="white"];
  node [shape=record, style="rounded,filled", fillcolor="#F8FAFC", color="#CBD5E1", fontname="Arial", fontsize=10];
  edge [color="#64748B", arrowsize=0.7, fontname="Arial", fontsize=9];

  Budget [label="{Budget / BudgetMetaData|type de budget|locale / devise|strictBudget}"];
  Account [label="{Account|accountName|accountType|onBudget|hidden|lastReconciledBalance}"];
  Transaction [label="{Transaction|date|amount|accountId|payeeId|categoryId|cleared|accepted|memo|transferTransactionId?}"];
  SubTx [label="{SubTransaction|hérite du modèle Transaction\nsans sous-transactions imbriquées}"];
  Schedule [label="{ScheduledTransaction|frequency|next date|accountId|payeeId|categoryId|amount|memo}"];
  Payee [label="{Payee|nom|règles associées|catégorie par défaut|favori?}"];
  Category [label="{Category / MonthlySubCategoryBudget|groupe|enveloppe mensuelle|activité|solde / rollover}"];
  Rule [label="{Rule|conditions|actions|ordre / spécificité|pré/post import}"];
  Report [label="{Report / AQL|requêtes|agrégations|graphiques / tables}"];
  Sync [label="{Sync State|syncId|knowledge|changelog|E2E optionnelle}"];

  Budget -> Category [label="contient / pilote"];
  Account -> Transaction [label="1..n"];
  Transaction -> Payee [label="référence"];
  Transaction -> Category [label="catégorise"];
  Transaction -> SubTx [label="0..n splits"];
  Schedule -> Transaction [label="génère / lie"];
  Rule -> Transaction [label="transforme"];
  Payee -> Rule [label="alimente"];
  Transaction -> Report [label="source analytique"];
  Budget -> Sync [label="réplique"];
  Transaction -> Sync [label="change sets"];
  Account -> Schedule [label="porte"];
}
