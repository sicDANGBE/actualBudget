digraph G {
graph [rankdir=TB, pad="0.25", nodesep="0.4", ranksep="0.5", fontname="Arial", bgcolor="white"];
node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#CBD5E1", fontname="Arial", fontsize=10, width=1.5];
edge [color="#475569", fontname="Arial", fontsize=9, arrowsize=0.7];
label="Séquence - Synchronisation multi-appareils"; labelloc=t; fontsize=14; fontname="Arial";
a0 [label="Device A"];
a1 [label="Core local"];
a2 [label="Sync Server"];
a3 [label="Device B"];
{ rank=same; a0; a1; a2; a3; }
a0 -> a1 [label="modifie budget localement"];
a1 -> a2 [label="envoie changelog / knowledge"];
