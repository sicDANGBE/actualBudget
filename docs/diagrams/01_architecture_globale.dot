
digraph G {
  graph [pad="0.3", nodesep="0.45", ranksep="0.7", fontname="Arial", bgcolor="white"];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#CBD5E1", fontname="Arial", fontsize=11, margin="0.12,0.08"];
  edge [color="#64748B", fontname="Arial", fontsize=10, arrowsize=0.8];

  subgraph cluster_clients {
    label="Couches client";
    color="#CBD5E1";
    style="rounded";
    web [label="Web app\nReact + Vite"];
    electron [label="Desktop app\nElectron wrapper"];
    mobile [label="Mobile/Web responsive UI\nmême code UI"];
  }

  ui [label="desktop-client\nComposants UI, hooks,\nmodales, navigation", fillcolor="#EEF2FF", color="#A5B4FC"];
  comp [label="component-library\nDesign system réutilisable", fillcolor="#EEF2FF", color="#A5B4FC"];
  core [label="loot-core\nNoyau métier\ntransactions, budgets,\nrègles, reports, AQL", fillcolor="#ECFDF5", color="#86EFAC"];
  worker [label="Runtime local de données\nWeb worker (web)\nou process Node/WebSocket (Electron)", fillcolor="#FEFCE8", color="#FDE68A"];
  sqlite [label="SQLite local\nbudget, tables internes,\nviews v_* et migrations", fillcolor="#FFF7ED", color="#FDBA74"];
  sync [label="sync-server\nsynchronisation multi-appareils,\nauthentification, secrets", fillcolor="#FDF2F8", color="#F9A8D4"];
  api [label="API / CLI\n@actual-app/api + CLI", fillcolor="#FDF2F8", color="#F9A8D4"];
  banks [label="Providers externes\nbank sync / import fichiers", fillcolor="#F1F5F9", color="#CBD5E1"];

  web -> ui;
  electron -> ui;
  mobile -> ui;
  ui -> comp [label="utilise"];
  ui -> worker [label="appels / bindings"];
  worker -> core [label="exécute le métier"];
  core -> sqlite [label="lit / écrit"];
  ui -> sync [label="sync optionnel"];
  sync -> sqlite [style=dashed, label="réplique de changements"];
  api -> core [label="accès programmatique"];
  core -> banks [label="import, enrichissement"];
  sync -> api [style=dashed, label="outils serveur"];
}
